{
  "name": "@clickshield/shared-rules",
  "version": "0.1.0",
  "description": "Pure, synchronous, deterministic rule engine for ClickShield threat detection",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "sync:surfaces": "node ./scripts/sync-surface-bundles.mjs",
    "verify:surfaces": "node ./scripts/verify-surface-bundles.mjs",
    "build:surfaces": "npm run build && npm run sync:surfaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "vitest": "^3.1.0"
  },
  "sideEffects": false,
  "dependencies": {
    "punycode": "^2.3.1",
    "tldts": "^7.0.27"
  }
}
