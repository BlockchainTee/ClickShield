{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-appclickshield-desktop",
  "version": "0.1.0",
  "identifier": "com.thomasbarnesiii.tauri-appclickshield-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tauri-appclickshield-desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:1420 ws://localhost:1420 http://127.0.0.1:4000; img-src 'self' data: blob:; object-src 'none'; frame-src 'none'; form-action 'none';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "clickshield_watchdog"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/BlockchainTee/ClickShield/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg2M0E1NUI1NDcxRTNFMUIKUldRYlBoNUh0VlU2aGxOUjM1WVMrZGh6WjRlM3kvMVBaclo5ZStmWGRwaUkyTU5zQ1JIYXFVRVUK"
    }
  }
}
